# Copy to .env and fill in. On Lovable Cloud these are auto-provisioned.

# Supabase (publishable / anon key — safe for client)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# Server-only Supabase config
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Lovable AI Gateway — used for resume / cover-letter / match scoring
LOVABLE_API_KEY="your-lovable-ai-gateway-key"

# Firecrawl — used for job discovery + extraction
FIRECRAWL_API_KEY="your-firecrawl-key"

# Resend — daily digest emails (optional)
RESEND_API_KEY="your-resend-key"

# Webhook / cron auth (optional)
WEBHOOK_SECRET="random-string"

CONTACT_EMAIL="you@example.com"
CONTACT_NAME="Your Name"